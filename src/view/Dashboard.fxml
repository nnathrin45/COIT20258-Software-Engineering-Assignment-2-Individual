<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.DashboardController"
      prefWidth="1000" prefHeight="850"
      style="-fx-background-color: #F5F5F5;">

    <HBox alignment="CENTER" prefHeight="50" style="-fx-background-color: #1B2A47;">
        <Label text="Disaster Response System (DRS)"
               style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
    </HBox>

    <HBox style="-fx-background-color: #2C3E5C;" spacing="0">
        <padding><Insets top="6" bottom="6" left="20" right="20"/></padding>
        <Button text="Report" onAction="#goReport"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 4 12 4 12;"/>
        <Button text="Assess" onAction="#goAssess"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 4 12 4 12;"/>
        <Button text="Assign" onAction="#goAssign"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 4 12 4 12;"/>
        <Button text="Update" onAction="#goUpdate"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-padding: 4 12 4 12;"/>
        <Button text="Dashboard" onAction="#goDashboard"
                style="-fx-background-color: #1B2A47; -fx-text-fill: white;
                       -fx-padding: 4 12 4 12; -fx-font-weight: bold;"/>
    </HBox>

    <!-- ALERT BANNER (Creative Feature 2 — visible only when critical incidents exist) -->
    <HBox fx:id="alertBanner" alignment="CENTER" visible="false" managed="false">
        <Label fx:id="alertText" text=""/>
    </HBox>

    <VBox spacing="15">
        <padding><Insets top="20" right="30" bottom="15" left="30"/></padding>

        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="Incident Dashboard"
                   style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #1B2A47;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Refresh" onAction="#handleRefresh"
                    style="-fx-background-color: #1B2A47; -fx-text-fill: white;
                           -fx-padding: 6 14 6 14;"/>
        </HBox>

        <!-- Summary Counts (Creative Feature 2) -->
        <HBox spacing="15" style="-fx-background-color: white; -fx-border-color: #CCCCCC;
                                  -fx-border-width: 1; -fx-border-radius: 4;">
            <padding><Insets top="15" right="25" bottom="15" left="25"/></padding>
            <Label fx:id="totalLabel" text="Total: 0"
                   style="-fx-font-weight: bold; -fx-font-size: 13px;"/>
            <Separator orientation="VERTICAL"/>
            <Label fx:id="criticalLabel" text="Critical: 0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FF0000; -fx-font-size: 13px;"/>
            <Label fx:id="highLabel" text="High: 0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FF8C00; -fx-font-size: 13px;"/>
            <Label fx:id="mediumLabel" text="Medium: 0"
                   style="-fx-font-weight: bold; -fx-text-fill: #FFA500; -fx-font-size: 13px;"/>
            <Label fx:id="lowLabel" text="Low: 0"
                   style="-fx-font-weight: bold; -fx-text-fill: #27AE60; -fx-font-size: 13px;"/>
        </HBox>

        <!-- Incident Table -->
        <VBox style="-fx-background-color: white; -fx-border-color: #CCCCCC;
                     -fx-border-width: 1; -fx-border-radius: 4;">
            <padding><Insets top="15" right="15" bottom="15" left="15"/></padding>
            <Label text="ALL INCIDENTS"
                   style="-fx-font-weight: bold; -fx-font-size: 11px; -fx-text-fill: #555555;"/>
            <Separator/>
            <TableView fx:id="incidentTable" prefHeight="400">
                <columns>
                    <TableColumn fx:id="idColumn" text="ID" prefWidth="100"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
                    <TableColumn fx:id="locationColumn" text="Location" prefWidth="220"/>
                    <TableColumn fx:id="severityColumn" text="Severity" prefWidth="100"/>
                    <TableColumn fx:id="priorityColumn" text="Priority" prefWidth="100"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="180"/>
                </columns>
            </TableView>
        </VBox>
    </VBox>

    <Region VBox.vgrow="ALWAYS"/>
    <HBox alignment="CENTER_LEFT" spacing="8" prefHeight="28"
          style="-fx-background-color: #E8E8E8; -fx-border-color: #CCCCCC; -fx-border-width: 1 0 0 0;">
        <padding><Insets left="15" right="15"/></padding>
        <Circle radius="5" fill="#27AE60"/>
        <Label text="System Online | User: Disaster Management Manager | Session Active"
               style="-fx-font-size: 11px; -fx-text-fill: #555555;"/>
    </HBox>

</VBox>
